    resources:
        mem_mb=16000,
        docker=DOCKER_IMAGE
    shell:
        "python3 {PIPELINE_DIR}/scripts/05_cross_sample_merge.py --sample_sheet {input.sample_sheet} --ref_tsv {input.ref} --mode {params.mode} --outdir {params.outdir} --indiv_dir {params.indiv_dir}"

rule final_callset:
